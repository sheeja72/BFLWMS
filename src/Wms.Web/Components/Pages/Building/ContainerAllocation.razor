@page "/building/container-allocation"
@rendermode RenderMode.InteractiveServer
@using System.Text
@using Wms.Core
@using Wms.Data.Lpm
@attribute [Authorize(Roles = "Admin,WHManager")]
@inject ContainerAllocationService Svc
@inject Microsoft.JSInterop.IJSRuntime JS

<PageTitle>WMS — Container Allocation</PageTitle>

<div class="aiwms-page-header">
    <h2>Container Allocation</h2>
    <p>Validate a container against the LPM source data, then run the allocation process.</p>
</div>

<div class="aiwms-section">
    <div class="aiwms-card-header">Inputs</div>
    <div style="display:grid; grid-template-columns: 1fr 1fr 1.5fr auto auto; gap:12px; align-items:end;">
        <div>
            <label style="display:block; font-size:11px; font-weight:700; color:var(--text-secondary); margin-bottom:4px;">COUNTRY *</label>
            <select @bind="_country" @bind:after="OnCountryChangedAsync" style="width:100%; padding:8px 10px; border:1px solid var(--border-default); border-radius:var(--r-sm); font-family:var(--font-body); font-size:13px; background:white;">
                <option value="">-- Select --</option>
                @foreach (var c in _countries) { <option value="@c">@c</option> }
            </select>
        </div>
        <div>
            <label style="display:block; font-size:11px; font-weight:700; color:var(--text-secondary); margin-bottom:4px;">WAREHOUSE *</label>
            <select @bind="_warehouse" style="width:100%; padding:8px 10px; border:1px solid var(--border-default); border-radius:var(--r-sm); font-family:var(--font-body); font-size:13px; background:white;">
                <option value="">-- Select --</option>
                @foreach (var w in _warehouses) { <option value="@w">@w</option> }
            </select>
        </div>
        <div>
            <label style="display:block; font-size:11px; font-weight:700; color:var(--text-secondary); margin-bottom:4px;">CONTAINER NO *</label>
            <input @bind="_contno" placeholder="e.g. AEINT6255" style="width:100%; padding:8px 10px; border:1px solid var(--border-default); border-radius:var(--r-sm); font-family:var(--font-mono); font-size:13px; background:white;" />
        </div>
        <button class="aiwms-btn aiwms-btn-secondary" @onclick="LoadPoDataAsync" disabled="@(_busy || !CanLoad)">
            Load PO Data
        </button>
        <button class="aiwms-btn aiwms-btn-primary" @onclick="ProcessAsync" disabled="@(_busy || !CanProcess)">
            Process
        </button>
    </div>

    @if (!string.IsNullOrEmpty(_message))
    {
        <div class="aiwms-alert @(_messageIsError ? "error" : "info")" style="margin-top:12px">@_message</div>
    }
</div>

@if (_poData.Count > 0)
{
    <div class="aiwms-section">
        <div class="aiwms-card-header">PO Data — @_poData.Count rows</div>
        <table class="aiwms-table">
            <thead>
                <tr>
                    <th>Contno</th>
                    <th>Receipt Dt</th>
                    <th>PO No</th>
                    <th>LPM</th>
                    <th>Buyer</th>
                    <th>Division</th>
                    <th>Brand</th>
                    <th style="text-align:right">Qty</th>
                    <th>Dest. Country</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var r in _poData)
                {
                    <tr>
                        <td>@r.Contno</td>
                        <td>@r.ContReceiptDT?.ToString("yyyy-MM-dd")</td>
                        <td>@r.PONO</td>
                        <td>@r.LPM</td>
                        <td>@r.Buyer</td>
                        <td>@r.Division</td>
                        <td>@r.Brand</td>
                        <td style="text-align:right">@r.Qty</td>
                        <td>@r.DestCountry</td>
                    </tr>
                }
            </tbody>
            <tfoot>
                <tr style="background:var(--bfl-grey-50); font-weight:800">
                    <td colspan="7" style="text-align:right">Total</td>
                    <td style="text-align:right">@_poData.Sum(r => r.Qty)</td>
                    <td></td>
                </tr>
            </tfoot>
        </table>
    </div>
}

@if (_validation is not null)
{
    <div class="aiwms-section">
        <div class="aiwms-card-header">
            Validation — @(_validation.Ok ? "ALL PASSED" : "BLOCKED")
        </div>
        <table class="aiwms-table">
            <thead><tr><th>Step</th><th>Status</th><th>Detail</th></tr></thead>
            <tbody>
                @foreach (var s in _validation.Steps)
                {
                    <tr>
                        <td>@s.Label</td>
                        <td>
                            <span class="aiwms-pill @(s.Ok ? "tier1" : "tier4")">
                                @(s.Ok ? "OK" : "FAIL")
                            </span>
                        </td>
                        <td>@s.Detail</td>
                    </tr>
                }
            </tbody>
        </table>

        @if (_validation.Ok)
        {
            <div class="aiwms-alert success" style="margin-top:12px">
                All checks passed. @(_allocation.Count == 0 ? "Computing allocation..." : $"{_allocation.Count} allocation rows computed.")
            </div>
        }
    </div>
}

@if (_allocation.Count > 0)
{
    <div class="aiwms-section">
        <div class="aiwms-card-header" style="display:flex; align-items:center; justify-content:space-between">
            <span>Allocation Preview — @_allocation.Count rows, total @_allocation.Sum(r => r.AllocQty) pcs</span>
            <span style="display:flex; gap:8px">
                <button class="aiwms-btn aiwms-btn-secondary" @onclick="ExportCsvAsync" disabled="@_busy">Export to Excel</button>
                <button class="aiwms-btn aiwms-btn-primary" @onclick="ConfirmSaveAsync" disabled="@(_busy || _saved)">@(_saved ? "Saved ✓" : "Confirm & Save")</button>
            </span>
        </div>
        <table class="aiwms-table aiwms-table-dense">
            <thead>
                <tr>
                    <th>Contno</th>
                    <th>OraPONo</th>
                    <th>ItemCode</th>
                    <th>PO Qty</th>
                    <th>ShopCode</th>
                    <th>Country</th>
                    <th>VolumeGroup</th>
                    <th style="text-align:right">SKUMax</th>
                    <th style="text-align:right">Alloc Qty</th>
                    <th style="text-align:right">RR Extra</th>
                    <th style="text-align:right">MerchNeed/Mo</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var r in _allocation)
                {
                    <tr>
                        <td>@r.Contno</td>
                        <td>@r.OraPONo</td>
                        <td>@r.ItemCode</td>
                        <td>@r.PoQty</td>
                        <td>@r.ShopCode</td>
                        <td>@r.Country</td>
                        <td>@r.VolumeGroup</td>
                        <td style="text-align:right">@r.SkuMax</td>
                        <td style="text-align:right">@r.AllocQty</td>
                        <td style="text-align:right">@(r.RoundRobinExtra > 0 ? r.RoundRobinExtra.ToString() : "")</td>
                        <td style="text-align:right">@r.MerchNeedMonth</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}

@code {
    private List<string> _countries = new();
    private List<string> _warehouses = new();
    private List<PoDataRow> _poData = new();
    private List<AllocationRow> _allocation = new();
    private bool _saved;
    private ContainerAllocationValidationResult? _validation;

    private string _country = "";
    private string _warehouse = "";
    private string _contno = "";
    private bool _busy;
    private string _message = "";
    private bool _messageIsError;

    private bool CanLoad => !string.IsNullOrWhiteSpace(_contno);
    private bool CanProcess => !string.IsNullOrWhiteSpace(_country)
                            && !string.IsNullOrWhiteSpace(_warehouse)
                            && !string.IsNullOrWhiteSpace(_contno);

    protected override async Task OnInitializedAsync()
    {
        try { _countries = await Svc.GetCountriesAsync(); }
        catch (Exception ex) { ShowError($"Failed to load countries: {ex.Message}"); }
    }

    private async Task OnCountryChangedAsync()
    {
        _warehouse = "";
        _warehouses = new();
        if (string.IsNullOrWhiteSpace(_country)) return;
        try { _warehouses = await Svc.GetWarehousesAsync(_country); }
        catch (Exception ex) { ShowError($"Failed to load warehouses: {ex.Message}"); }
    }

    private async Task LoadPoDataAsync()
    {
        _busy = true; _message = ""; _validation = null; _allocation = new(); _saved = false;
        try
        {
            _poData = await Svc.LoadPoDataAsync(_contno);
            if (_poData.Count == 0) ShowInfo("No rows found in usaorgfile_LPM for this container.");
        }
        catch (Exception ex) { ShowError($"Load failed: {ex.Message}"); }
        finally { _busy = false; }
    }

    private async Task ProcessAsync()
    {
        _busy = true; _message = ""; _allocation = new(); _saved = false;
        try
        {
            _validation = await Svc.ValidateAsync(_country, _contno);
            if (!_validation.Ok)
            {
                ShowError("Validation failed — see steps below.");
                return;
            }
            _allocation = await Svc.ProcessAllocationAsync(_contno);
            if (_allocation.Count == 0)
                ShowError("No allocation rows produced. Check LPM_EOM_Output (current month) + LPM_SKUMaxRule coverage.");
            else
                ShowInfo($"Allocation computed: {_allocation.Count} rows, {_allocation.Sum(r => r.AllocQty)} pcs.");
        }
        catch (Exception ex) { ShowError($"Process failed: {ex.Message}"); }
        finally { _busy = false; }
    }

    private async Task ExportCsvAsync()
    {
        var sb = new StringBuilder();
        sb.AppendLine("Contno,OraPONo,ItemCode,PoQty,ShopCode,Country,VolumeGroup,SkuMax,AllocQty,RoundRobinExtra,MerchNeedMonth,DivCode,LPM,LPMDt");
        foreach (var r in _allocation)
        {
            sb.Append(Csv(r.Contno)).Append(',').Append(Csv(r.OraPONo)).Append(',').Append(Csv(r.ItemCode)).Append(',')
              .Append(r.PoQty).Append(',').Append(Csv(r.ShopCode)).Append(',').Append(Csv(r.Country)).Append(',')
              .Append(Csv(r.VolumeGroup)).Append(',').Append(r.SkuMax).Append(',').Append(r.AllocQty).Append(',')
              .Append(r.RoundRobinExtra).Append(',').Append(r.MerchNeedMonth).Append(',').Append(r.DivCode).Append(',')
              .Append(Csv(r.LPM)).Append(',').Append(r.LPMDt?.ToString("yyyy-MM-dd"))
              .AppendLine();
        }
        var bytes = Encoding.UTF8.GetBytes(sb.ToString());
        var b64 = Convert.ToBase64String(bytes);
        var filename = $"allocation_{_contno}_{DateTime.Now:yyyyMMdd_HHmmss}.csv";
        await JS.InvokeVoidAsync("eval", $@"
            (function() {{
                var a = document.createElement('a');
                a.href = 'data:text/csv;base64,{b64}';
                a.download = '{filename}';
                document.body.appendChild(a); a.click(); document.body.removeChild(a);
            }})();");
    }

    private static string Csv(string? s) => s is null ? ""
        : (s.Contains(',') || s.Contains('"') || s.Contains('\n'))
            ? "\"" + s.Replace("\"", "\"\"") + "\""
            : s;

    private async Task ConfirmSaveAsync()
    {
        _busy = true; _message = "";
        try
        {
            var n = await Svc.SaveAllocationAsync(_allocation);
            _saved = true;
            ShowInfo($"Saved {n} rows to LPMSIM.WMS_ContAllocationData.");
        }
        catch (Exception ex) { ShowError($"Save failed: {ex.Message}"); }
        finally { _busy = false; }
    }

    private void ShowError(string msg)   { _message = msg; _messageIsError = true; }
    private void ShowInfo(string msg)    { _message = msg; _messageIsError = false; }
}
