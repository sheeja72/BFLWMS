@page "/building/container-allocation"
@rendermode RenderMode.InteractiveServer
@using System.Text
@using Wms.Core
@using Wms.Data.Lpm
@attribute [Authorize(Roles = "Admin,WHManager")]
@inject ContainerAllocationService Svc
@inject ICurrentUser CurrentUser
@inject Microsoft.JSInterop.IJSRuntime JS

<PageTitle>WMS — Container Allocation</PageTitle>

<div class="aiwms-page-header">
    <h2>Container Allocation</h2>
    <p>Validate a container against the LPM source data, then run the allocation process.</p>
</div>

<div class="aiwms-section">
    <div class="aiwms-card-header">Inputs</div>
    <div style="display:grid; grid-template-columns: 1fr 1fr 1fr 180px auto auto; gap:12px; align-items:end; flex-wrap:wrap">
        <div>
            <label style="display:block; font-size:11px; font-weight:700; color:var(--text-secondary); margin-bottom:4px;">COUNTRY *</label>
            <select @bind="_country" @bind:after="OnCountryChangedAsync" style="width:100%; padding:8px 10px; border:1px solid var(--border-default); border-radius:var(--r-sm); font-family:var(--font-body); font-size:13px; background:white;">
                <option value="">-- Select --</option>
                @foreach (var c in _countries) { <option value="@c">@c</option> }
            </select>
        </div>
        <div>
            <label style="display:block; font-size:11px; font-weight:700; color:var(--text-secondary); margin-bottom:4px;">WAREHOUSE *</label>
            <select @bind="_warehouse" style="width:100%; padding:8px 10px; border:1px solid var(--border-default); border-radius:var(--r-sm); font-family:var(--font-body); font-size:13px; background:white;">
                <option value="">-- Select --</option>
                @foreach (var w in _warehouses) { <option value="@w">@w</option> }
            </select>
        </div>
        <div>
            <label style="display:block; font-size:11px; font-weight:700; color:var(--text-secondary); margin-bottom:4px;">RUN OPTION</label>
            <select @bind="_runOption" style="width:100%; padding:8px 10px; border:1px solid var(--border-default); border-radius:var(--r-sm); font-family:var(--font-body); font-size:13px; background:white;">
                <option value="FillSKUMax">Fill SKUMax</option>
                <option value="RoundRobin">Round Robin</option>
            </select>
        </div>
        <div>
            <label style="display:block; font-size:11px; font-weight:700; color:var(--text-secondary); margin-bottom:4px;">CONTAINER NO *</label>
            <input @bind="_contno" @bind:after="OnContnoChangedAsync" placeholder="e.g. AEINT6255" style="width:100%; padding:8px 10px; border:1px solid var(--border-default); border-radius:var(--r-sm); font-family:var(--font-mono); font-size:13px; background:white;" />
        </div>
        <button class="aiwms-btn aiwms-btn-secondary" @onclick="LoadPoDataAsync" disabled="@(_busy || !CanLoad)">Load PO Data</button>
        <button class="aiwms-btn aiwms-btn-primary" @onclick="ProcessAsync" disabled="@(_busy || !CanProcess || _status?.HasFinal == true)">
            @(_status?.HasFinal == true ? "🔒 Locked" : "Process")
        </button>
    </div>
    @if (_allocation.Count > 0 || _status?.HasDraft == true)
    {
        <div style="display:flex; gap:12px; margin-top:12px; flex-wrap:wrap">
            @if (_allocation.Count > 0)
            {
                <button class="aiwms-btn aiwms-btn-success" @onclick="ConfirmSaveAsync" disabled="@_busy">Confirm &amp; Save</button>
            }
            @if (_status?.HasDraft == true)
            {
                <button class="aiwms-btn aiwms-btn-secondary" @onclick="ViewDraftAsync" disabled="@_busy">View Draft (@_status.DraftRows rows)</button>
            }
        </div>
    }

    @if (_progressTotal > 0 || _busy)
    {
        <div style="margin-top:14px; padding:12px 14px; background:var(--bfl-yellow-lite); border:1px solid var(--bfl-yellow); border-radius:var(--r-sm)">
            <div style="display:flex; justify-content:space-between; font-family:var(--font-display); font-size:13px; font-weight:800; color:var(--bfl-black); margin-bottom:6px">
                <span>@(_progressTotal == 0 ? "Processing…" : $"Processing items… {_progressCurrent} / {_progressTotal}") @(_progressItem is null ? "" : $"  →  {_progressItem}")</span>
                <span>@(_progressTotal == 0 ? "" : $"{(int)(100.0 * _progressCurrent / _progressTotal)}%")</span>
            </div>
            <div style="width:100%; height:10px; background:white; border-radius:var(--r-pill); overflow:hidden; border:1px solid var(--bfl-yellow-hov)">
                <div style="height:100%; background:var(--bfl-yellow); width:@(_progressTotal == 0 ? 0 : (int)(100.0 * _progressCurrent / _progressTotal))%; transition:width .15s ease"></div>
            </div>
        </div>
    }

    @if (!string.IsNullOrEmpty(_message))
    {
        <div class="aiwms-alert @(_messageIsError ? "error" : "info")" style="margin-top:12px">@_message</div>
    }
</div>

@if (_poData.Count > 0)
{
    <div class="aiwms-section">
        <div class="aiwms-card-header">PO Data — @_poData.Count rows</div>
        <table class="aiwms-table">
            <thead>
                <tr><th>Contno</th><th>Receipt Dt</th><th>PO No</th><th>LPM</th><th>Buyer</th><th>Division</th><th>Brand</th><th style="text-align:right">Qty</th><th>Dest. Country</th></tr>
            </thead>
            <tbody>
                @foreach (var r in _poData)
                {
                    <tr>
                        <td>@r.Contno</td><td>@r.ContReceiptDT?.ToString("yyyy-MM-dd")</td><td>@r.PONO</td>
                        <td>@r.LPM</td><td>@r.Buyer</td><td>@r.Division</td><td>@r.Brand</td>
                        <td style="text-align:right">@r.Qty</td><td>@r.DestCountry</td>
                    </tr>
                }
            </tbody>
            <tfoot><tr style="background:var(--bfl-grey-50); font-weight:800"><td colspan="7" style="text-align:right">Total</td><td style="text-align:right">@_poData.Sum(r => r.Qty)</td><td></td></tr></tfoot>
        </table>
    </div>
}

@if (_allocation.Count > 0)
{
    <div class="aiwms-section">
        <div class="aiwms-card-header" style="display:flex; align-items:center; justify-content:space-between; flex-wrap:wrap; gap:8px">
            @{
                var rendered = Filtered.ToList();
                var capped = _filteredCount > MAX_RENDER_ROWS;
            }
            <span>Allocation @(_status?.HasFinal == true ? "(FINAL)" : _status?.HasDraft == true ? "(Draft)" : "Preview") — @rendered.Count of @_filteredCount filtered (of @_allocation.Count total), total @rendered.Sum(r => r.AllocQty) pcs shown@(capped ? $" — capped at {MAX_RENDER_ROWS}, use filters to narrow" : "")</span>
            <span style="display:flex; gap:8px">
                <button class="aiwms-btn aiwms-btn-secondary" @onclick="ExportCsvAsync">Export to Excel</button>
            </span>
        </div>

        <!-- Report view picker -->
        <div style="display:flex; gap:14px; align-items:center; padding:10px 0; border-bottom:1px solid var(--border-default); margin-bottom:10px">
            <strong style="font-size:11px; text-transform:uppercase; letter-spacing:1px; color:var(--text-secondary)">Report:</strong>
            <label style="display:flex; align-items:center; gap:4px; cursor:pointer"><input type="radio" name="rv" value="ItemStore" checked="@(_view == "ItemStore")" @onchange="@(_ => SetView("ItemStore"))" /> Item × Store</label>
            <label style="display:flex; align-items:center; gap:4px; cursor:pointer"><input type="radio" name="rv" value="ItemSummary" checked="@(_view == "ItemSummary")" @onchange="@(_ => SetView("ItemSummary"))" /> Item Summary</label>
            <label style="display:flex; align-items:center; gap:4px; cursor:pointer"><input type="radio" name="rv" value="Store" checked="@(_view == "Store")" @onchange="@(_ => SetView("Store"))" /> Store</label>
            <label style="display:flex; align-items:center; gap:4px; cursor:pointer"><input type="radio" name="rv" value="CountrySummary" checked="@(_view == "CountrySummary")" @onchange="@(_ => SetView("CountrySummary"))" /> Country Summary</label>
        </div>

        <!-- Filters -->
        <div style="display:grid; grid-template-columns: repeat(4, 1fr); gap:10px; padding-bottom:12px">
            <div>
                <label style="font-size:11px; font-weight:800; color:var(--bfl-black)">DIVISION</label>
                <input @bind="_divSearch" @bind:event="oninput" placeholder="search…" style="width:100%; margin-bottom:4px; padding:6px 8px; font-size:12px; border:1px solid var(--border-default); border-radius:var(--r-sm); background:white" />
                <MudSelect T="string" Dense="true" MultiSelection="true" SelectAll="true"
                           SelectedValues="_filterDivs" SelectedValuesChanged="@(v => _filterDivs = v.ToHashSet())"
                           Placeholder="All" Variant="Variant.Outlined" Margin="Margin.Dense">
                    @foreach (var d in _allocation.Where(a => a.Division is not null).Select(a => a.Division!).Distinct()
                                                  .Where(x => string.IsNullOrEmpty(_divSearch) || x.Contains(_divSearch, StringComparison.OrdinalIgnoreCase))
                                                  .OrderBy(x => x)) { <MudSelectItem T="string" Value="@d">@d</MudSelectItem> }
                </MudSelect>
            </div>
            <div>
                <label style="font-size:11px; font-weight:800; color:var(--bfl-black)">STORE NAME</label>
                <input @bind="_storeSearch" @bind:event="oninput" placeholder="search…" style="width:100%; margin-bottom:4px; padding:6px 8px; font-size:12px; border:1px solid var(--border-default); border-radius:var(--r-sm); background:white" />
                <MudSelect T="string" Dense="true" MultiSelection="true" SelectAll="true"
                           SelectedValues="_filterStores" SelectedValuesChanged="@(v => _filterStores = v.ToHashSet())"
                           Placeholder="All" Variant="Variant.Outlined" Margin="Margin.Dense">
                    @foreach (var s in _allocation.Where(a => a.StoreName is not null).Select(a => a.StoreName!).Distinct()
                                                  .Where(x => string.IsNullOrEmpty(_storeSearch) || x.Contains(_storeSearch, StringComparison.OrdinalIgnoreCase))
                                                  .OrderBy(x => x)) { <MudSelectItem T="string" Value="@s">@s</MudSelectItem> }
                </MudSelect>
            </div>
            <div>
                <label style="font-size:11px; font-weight:800; color:var(--bfl-black)">PO NO</label>
                <input @bind="_poSearch" @bind:event="oninput" placeholder="search…" style="width:100%; margin-bottom:4px; padding:6px 8px; font-size:12px; border:1px solid var(--border-default); border-radius:var(--r-sm); background:white" />
                <MudSelect T="string" Dense="true" MultiSelection="true" SelectAll="true"
                           SelectedValues="_filterPos" SelectedValuesChanged="@(v => _filterPos = v.ToHashSet())"
                           Placeholder="All" Variant="Variant.Outlined" Margin="Margin.Dense">
                    @foreach (var p in _allocation.Select(a => a.OraPONo).Distinct()
                                                  .Where(x => string.IsNullOrEmpty(_poSearch) || x.Contains(_poSearch, StringComparison.OrdinalIgnoreCase))
                                                  .OrderBy(x => x)) { <MudSelectItem T="string" Value="@p">@p</MudSelectItem> }
                </MudSelect>
            </div>
            <div>
                <label style="font-size:11px; font-weight:800; color:var(--bfl-black)">ITEMCODE (contains)</label>
                <input @bind="_filterItemCode" @bind:event="oninput" placeholder="search…" style="width:100%; padding:8px 10px; font-size:13px; border:1px solid var(--border-default); border-radius:var(--r-sm); background:white" />
                <div style="margin-top:4px"><a href="#" style="font-size:11px" @onclick:preventDefault @onclick="ClearFilters">Clear all filters</a></div>
            </div>
        </div>

        @if (_view == "ItemStore")
        {
            <table class="aiwms-table aiwms-table-dense">
                <thead>
                    <tr>
                        <th style="cursor:pointer" @onclick='() => Sort("OraPONo")'>OraPONo @SortArrow("OraPONo")</th>
                        <th style="cursor:pointer" @onclick='() => Sort("ItemCode")'>ItemCode @SortArrow("ItemCode")</th>
                        <th style="cursor:pointer" @onclick='() => Sort("ItemName")'>Item Name @SortArrow("ItemName")</th>
                        <th style="cursor:pointer" @onclick='() => Sort("Brand")'>Brand @SortArrow("Brand")</th>
                        <th style="cursor:pointer" @onclick='() => Sort("Division")'>Division @SortArrow("Division")</th>
                        <th style="cursor:pointer; text-align:right" @onclick='() => Sort("PoQty")'>PO Qty @SortArrow("PoQty")</th>
                        <th style="cursor:pointer" @onclick='() => Sort("StoreID")'>Store ID @SortArrow("StoreID")</th>
                        <th style="cursor:pointer" @onclick='() => Sort("StoreName")'>Store Name @SortArrow("StoreName")</th>
                        <th style="cursor:pointer" @onclick='() => Sort("Country")'>Country @SortArrow("Country")</th>
                        <th style="cursor:pointer" @onclick='() => Sort("VolumeGroup")'>VolumeGroup @SortArrow("VolumeGroup")</th>
                        <th style="cursor:pointer; text-align:right" @onclick='() => Sort("MerchNeedMonth")'>MerchNeed/Mo @SortArrow("MerchNeedMonth")</th>
                        <th style="cursor:pointer; text-align:right" @onclick='() => Sort("SkuMax")'>SKUMax @SortArrow("SkuMax")</th>
                        <th style="cursor:pointer; text-align:right" @onclick='() => Sort("AllocQty")'>Alloc Qty @SortArrow("AllocQty")</th>
                        <th style="text-align:right">RR Extra</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var r in Filtered)
                    {
                        <tr>
                            <td>@r.OraPONo</td><td>@r.ItemCode</td><td>@r.ItemName</td><td>@r.Brand</td><td>@r.Division</td>
                            <td style="text-align:right">@r.PoQty</td>
                            <td>@r.StoreID</td><td>@r.StoreName</td><td>@r.Country</td>
                            <td>@r.VolumeGroup</td><td style="text-align:right">@r.MerchNeedMonth</td>
                            <td style="text-align:right">@r.SkuMax</td>
                            <td style="text-align:right">@r.AllocQty</td>
                            <td style="text-align:right">@(r.RoundRobinExtra > 0 ? r.RoundRobinExtra.ToString() : "")</td>
                        </tr>
                    }
                </tbody>
            </table>
        }
        else if (_view == "ItemSummary")
        {
            <table class="aiwms-table aiwms-table-dense">
                <thead>
                    <tr>
                        <th style="cursor:pointer" @onclick='() => Sort("OraPONo")'>OraPONo @SortArrow("OraPONo")</th>
                        <th style="cursor:pointer" @onclick='() => Sort("ItemCode")'>ItemCode @SortArrow("ItemCode")</th>
                        <th style="cursor:pointer" @onclick='() => Sort("ItemName")'>Item Name @SortArrow("ItemName")</th>
                        <th style="cursor:pointer" @onclick='() => Sort("Brand")'>Brand @SortArrow("Brand")</th>
                        <th style="cursor:pointer" @onclick='() => Sort("Division")'>Division @SortArrow("Division")</th>
                        <th style="cursor:pointer; text-align:right" @onclick='() => Sort("PoQty")'>PO Qty @SortArrow("PoQty")</th>
                        <th style="cursor:pointer; text-align:right" @onclick='() => Sort("TotalAlloc")'>Total Alloc @SortArrow("TotalAlloc")</th>
                        <th style="cursor:pointer; text-align:right" @onclick='() => Sort("Stores")'>Stores @SortArrow("Stores")</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var g in ItemSummaryRows)
                    {
                        <tr>
                            <td>@g.OraPONo</td><td>@g.ItemCode</td><td>@g.ItemName</td><td>@g.Brand</td><td>@g.Division</td>
                            <td style="text-align:right">@g.PoQty</td>
                            <td style="text-align:right">@g.TotalAlloc</td>
                            <td style="text-align:right">@g.Stores</td>
                        </tr>
                    }
                </tbody>
            </table>
        }
        else if (_view == "Store")
        {
            <table class="aiwms-table aiwms-table-dense">
                <thead>
                    <tr>
                        <th style="cursor:pointer" @onclick='() => Sort("StoreID")'>Store ID @SortArrow("StoreID")</th>
                        <th style="cursor:pointer" @onclick='() => Sort("StoreName")'>Store Name @SortArrow("StoreName")</th>
                        <th style="cursor:pointer" @onclick='() => Sort("Country")'>Country @SortArrow("Country")</th>
                        <th style="cursor:pointer" @onclick='() => Sort("VolumeGroup")'>VolumeGroup @SortArrow("VolumeGroup")</th>
                        <th style="cursor:pointer; text-align:right" @onclick='() => Sort("MerchNeedMonth")'>MerchNeed/Mo @SortArrow("MerchNeedMonth")</th>
                        <th style="cursor:pointer" @onclick='() => Sort("Division")'>Division @SortArrow("Division")</th>
                        <th style="cursor:pointer" @onclick='() => Sort("Brand")'>Brand @SortArrow("Brand")</th>
                        <th style="cursor:pointer; text-align:right" @onclick='() => Sort("PoQtySum")'>PO Qty (sum) @SortArrow("PoQtySum")</th>
                        <th style="cursor:pointer; text-align:right" @onclick='() => Sort("AllocSum")'>Allocated Qty @SortArrow("AllocSum")</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var g in StoreRows)
                    {
                        <tr>
                            <td>@g.StoreID</td><td>@g.StoreName</td><td>@g.Country</td><td>@g.VolumeGroup</td>
                            <td style="text-align:right">@g.MerchNeedMonth</td><td>@g.Division</td><td>@g.Brand</td>
                            <td style="text-align:right">@g.PoQtySum</td>
                            <td style="text-align:right">@g.AllocSum</td>
                        </tr>
                    }
                </tbody>
            </table>
        }
        else if (_view == "CountrySummary")
        {
            <table class="aiwms-table aiwms-table-dense">
                <thead>
                    <tr>
                        <th style="cursor:pointer" @onclick='() => Sort("Country")'>Country @SortArrow("Country")</th>
                        <th style="cursor:pointer; text-align:right" @onclick='() => Sort("StoresCount")'>Stores Count @SortArrow("StoresCount")</th>
                        <th style="cursor:pointer" @onclick='() => Sort("OraPONo")'>PO No @SortArrow("OraPONo")</th>
                        <th style="cursor:pointer" @onclick='() => Sort("Division")'>Division @SortArrow("Division")</th>
                        <th style="cursor:pointer; text-align:right" @onclick='() => Sort("PoQty")'>PO Qty @SortArrow("PoQty")</th>
                        <th style="cursor:pointer; text-align:right" @onclick='() => Sort("AllocQty")'>Allocated Qty @SortArrow("AllocQty")</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var g in CountrySummaryRows)
                    {
                        <tr>
                            <td>@g.Country</td>
                            <td style="text-align:right">@g.StoresCount</td>
                            <td>@g.OraPONo</td>
                            <td>@g.Division</td>
                            <td style="text-align:right">@g.PoQty</td>
                            <td style="text-align:right">@g.AllocQty</td>
                        </tr>
                    }
                </tbody>
            </table>
        }
    </div>
}

@if (_validation is not null && _allocation.Count == 0)
{
    <div class="aiwms-section">
        <div class="aiwms-card-header">Validation — @(_validation.Ok ? "ALL PASSED" : "BLOCKED")</div>
        <table class="aiwms-table">
            <thead><tr><th>Step</th><th>Status</th><th>Detail</th></tr></thead>
            <tbody>
                @foreach (var s in _validation.Steps)
                {
                    <tr>
                        <td>@s.Label</td>
                        <td><span class="aiwms-pill @(s.Ok ? "tier1" : "tier4")">@(s.Ok ? "OK" : "FAIL")</span></td>
                        <td>@s.Detail</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}

@code {
    private List<string> _countries = new();
    private List<string> _warehouses = new();
    private List<PoDataRow> _poData = new();
    private List<AllocationRow> _allocation = new();
    private AllocationStatus? _status;
    private ContainerAllocationValidationResult? _validation;

    private string _country = "";
    private string _warehouse = "";
    private string _contno = "";
    private string _runOption = "FillSKUMax";
    private bool _busy;
    private string _message = "";
    private bool _messageIsError;
    private int _progressCurrent, _progressTotal;
    private string? _progressItem;

    private string _view = "Store";  // Store summary loads fastest — no per-item rows
    private string? _sortKey;
    private bool _sortAsc = true;
    private HashSet<string> _filterDivs = new();
    private HashSet<string> _filterStores = new();
    private HashSet<string> _filterPos = new();
    private string _filterItemCode = "";
    private string _divSearch = "";
    private string _storeSearch = "";
    private string _poSearch = "";

    private bool CanLoad => !string.IsNullOrWhiteSpace(_contno);
    private bool CanProcess => !string.IsNullOrWhiteSpace(_country)
                            && !string.IsNullOrWhiteSpace(_warehouse)
                            && !string.IsNullOrWhiteSpace(_contno);

    protected override async Task OnInitializedAsync()
    {
        try { _countries = await Svc.GetCountriesAsync(); }
        catch (Exception ex) { ShowError($"Failed to load countries: {ex.Message}"); }

        // Default Country + Warehouse from the logged-in user's WmsUser row.
        await CurrentUser.EnsureLoadedAsync();
        if (!string.IsNullOrWhiteSpace(CurrentUser.Country) && _countries.Contains(CurrentUser.Country!))
        {
            _country = CurrentUser.Country!;
            try { _warehouses = await Svc.GetWarehousesAsync(_country); }
            catch { _warehouses = new(); }
            if (!string.IsNullOrWhiteSpace(CurrentUser.Warehouse) && _warehouses.Contains(CurrentUser.Warehouse!))
                _warehouse = CurrentUser.Warehouse!;
        }
    }

    private async Task OnCountryChangedAsync()
    {
        _warehouse = ""; _warehouses = new();
        if (string.IsNullOrWhiteSpace(_country)) return;
        try { _warehouses = await Svc.GetWarehousesAsync(_country); }
        catch (Exception ex) { ShowError($"Failed to load warehouses: {ex.Message}"); }
        await RefreshStatusAsync();
    }

    private async Task OnContnoChangedAsync()
    {
        await RefreshStatusAsync();
    }

    private async Task RefreshStatusAsync()
    {
        if (string.IsNullOrWhiteSpace(_country) || string.IsNullOrWhiteSpace(_contno))
        {
            _status = null; return;
        }
        try
        {
            _status = await Svc.GetStatusAsync(_country, _contno);
            // Recall prior Run Option when revisiting the same container.
            if (!string.IsNullOrEmpty(_status?.DraftRunOption))
                _runOption = _status.DraftRunOption!;
        }
        catch { _status = null; }
    }

    private async Task LoadPoDataAsync()
    {
        _busy = true; _message = ""; _validation = null; _allocation = new();
        try
        {
            _poData = await Svc.LoadPoDataAsync(_contno);
            if (_poData.Count == 0) ShowInfo("No rows found in usaorgfile_LPM for this container.");
            await RefreshStatusAsync();
        }
        catch (Exception ex) { ShowError($"Load failed: {ex.Message}"); }
        finally { _busy = false; }
    }

    private async Task ProcessAsync()
    {
        _busy = true; _message = ""; _allocation = new();
        _progressCurrent = 0; _progressTotal = 0; _progressItem = null;
        try
        {
            var progress = new Progress<AllocationProgress>(async p => {
                _progressCurrent = p.Current; _progressTotal = p.Total; _progressItem = p.CurrentItem;
                await InvokeAsync(StateHasChanged);
            });
            _validation = await Svc.ValidateAsync(_country, _contno, progress);
            if (!_validation.Ok) { ShowError("Validation failed — see steps below."); return; }
            // Reset progress for the Process phase so the bar starts fresh at 0/N.
            _progressCurrent = 0; _progressTotal = 0; _progressItem = null;
            var ro = _runOption == "RoundRobin" ? RunOption.RoundRobin : RunOption.FillSKUMax;
            _allocation = await Svc.ProcessAllocationAsync(_contno, progress, ro);
            if (_allocation.Count == 0)
            {
                ShowError("No allocation rows produced. Check LPM_EOM_Output + LPM_SKUMaxRule coverage.");
            }
            else
            {
                // Auto-save draft so the user doesn't have to click a separate button.
                await Svc.SaveDraftAsync(_country, _contno, _allocation, _warehouse, ro);
                await RefreshStatusAsync();
                ShowInfo($"Allocation computed and draft saved: {_allocation.Count} rows, {_allocation.Sum(r => r.AllocQty)} pcs.");
            }
        }
        catch (Exception ex) { ShowError($"Process failed: {ex.Message}"); }
        finally { _busy = false; _progressTotal = 0; }
    }

    private async Task ViewDraftAsync()
    {
        _busy = true; _message = ""; _allocation = new();
        // Clear any stale filters / sort so the first render is small
        _filterDivs = new(); _filterStores = new(); _filterPos = new(); _filterItemCode = "";
        _sortKey = null;
        await InvokeAsync(StateHasChanged);
        try
        {
            var draft = await Svc.LoadDraftAsync(_country, _contno);
            _allocation = draft;
            ShowInfo($"Loaded draft — {_allocation.Count} rows (showing first {Math.Min(MAX_RENDER_ROWS, _allocation.Count)}; filter to narrow).");
        }
        catch (Exception ex) { ShowError($"Load draft failed: {ex.Message}"); }
        finally { _busy = false; }
    }

    private async Task ConfirmSaveAsync()
    {
        _busy = true; _message = "";
        try
        {
            var n = await Svc.SaveAllocationAsync(_allocation);
            await RefreshStatusAsync();
            ShowInfo($"Saved {n} rows to LPMSIM.WMS_ContAllocationData.");
        }
        catch (Exception ex) { ShowError($"Save failed: {ex.Message}"); }
        finally { _busy = false; }
    }

    private async Task ExportCsvAsync()
    {
        var sb = new StringBuilder();
        sb.AppendLine("Contno,OraPONo,ItemCode,ItemName,Brand,PoQty,StoreID,StoreName,Country,Division,VolumeGroup,SkuMax,AllocQty,RoundRobinExtra,MerchNeedMonth,LPM,LPMDt");
        foreach (var r in Filtered)
        {
            sb.Append(Csv(r.Contno)).Append(',').Append(Csv(r.OraPONo)).Append(',').Append(Csv(r.ItemCode)).Append(',')
              .Append(Csv(r.ItemName)).Append(',').Append(Csv(r.Brand)).Append(',').Append(r.PoQty).Append(',')
              .Append(Csv(r.StoreID)).Append(',').Append(Csv(r.StoreName)).Append(',').Append(Csv(r.Country)).Append(',')
              .Append(Csv(r.Division)).Append(',').Append(Csv(r.VolumeGroup)).Append(',')
              .Append(r.SkuMax).Append(',').Append(r.AllocQty).Append(',').Append(r.RoundRobinExtra).Append(',')
              .Append(r.MerchNeedMonth).Append(',').Append(Csv(r.LPM)).Append(',').Append(r.LPMDt?.ToString("yyyy-MM-dd"))
              .AppendLine();
        }
        var b64 = Convert.ToBase64String(Encoding.UTF8.GetBytes(sb.ToString()));
        var filename = $"allocation_{_contno}_{_view}_{DateTime.Now:yyyyMMdd_HHmmss}.csv";
        await JS.InvokeVoidAsync("eval", $"(function(){{var a=document.createElement('a');a.href='data:text/csv;base64,{b64}';a.download='{filename}';document.body.appendChild(a);a.click();document.body.removeChild(a);}})();");
    }

    private static string Csv(string? s) => s is null ? ""
        : (s.Contains(',') || s.Contains('"') || s.Contains('\n')) ? "\"" + s.Replace("\"", "\"\"") + "\"" : s;

    // --- Filtering + sorting ---
    private const int MAX_RENDER_ROWS = 1000;
    private int _filteredCount;

    // No cap, no sort — used by grouped views (Item Summary, Store, Country Summary)
    // and as the base for the capped+sorted ItemStore `Filtered`.
    private IEnumerable<AllocationRow> FilteredAll
    {
        get
        {
            IEnumerable<AllocationRow> q = _allocation;
            if (_filterDivs.Count   > 0) q = q.Where(r => r.Division   is not null && _filterDivs.Contains(r.Division));
            if (_filterStores.Count > 0) q = q.Where(r => r.StoreName  is not null && _filterStores.Contains(r.StoreName));
            if (_filterPos.Count    > 0) q = q.Where(r => _filterPos.Contains(r.OraPONo));
            if (!string.IsNullOrWhiteSpace(_filterItemCode))
                q = q.Where(r => r.ItemCode.Contains(_filterItemCode, StringComparison.OrdinalIgnoreCase));
            return q;
        }
    }

    private IEnumerable<AllocationRow> Filtered
    {
        get
        {
            IEnumerable<AllocationRow> q = FilteredAll;
            if (_sortKey is not null)
            {
                Func<AllocationRow, object?> k = _sortKey switch {
                    "OraPONo" => r => r.OraPONo,
                    "ItemCode" => r => r.ItemCode,
                    "ItemName" => r => r.ItemName,
                    "Brand" => r => r.Brand,
                    "Division" => r => r.Division,
                    "PoQty" => r => r.PoQty,
                    "StoreID" => r => r.StoreID,
                    "StoreName" => r => r.StoreName,
                    "Country" => r => r.Country,
                    "VolumeGroup" => r => r.VolumeGroup,
                    "MerchNeedMonth" => r => r.MerchNeedMonth,
                    "SkuMax" => r => r.SkuMax,
                    "AllocQty" => r => r.AllocQty,
                    _ => r => r.OraPONo,
                };
                q = _sortAsc ? q.OrderBy(k) : q.OrderByDescending(k);
            }
            var list = q.ToList();
            _filteredCount = list.Count;
            return list.Take(MAX_RENDER_ROWS);
        }
    }

    // --- Grouped view row types + getters (sorted by _sortKey if applicable) ---
    private record ItemSummaryRowVm(string OraPONo, string ItemCode, string? ItemName, string? Brand, string? Division, int PoQty, int TotalAlloc, int Stores);
    private record StoreRowVm(string StoreID, string? StoreName, string Country, string VolumeGroup, int MerchNeedMonth, string? Division, string Brand, int PoQtySum, int AllocSum);
    private record CountrySummaryRowVm(string Country, int StoresCount, string OraPONo, string? Division, int PoQty, int AllocQty);

    private IEnumerable<ItemSummaryRowVm> ItemSummaryRows
    {
        get
        {
            var rows = FilteredAll
                .GroupBy(r => new { r.OraPONo, r.ItemCode })
                .Select(g => new ItemSummaryRowVm(g.Key.OraPONo, g.Key.ItemCode,
                    g.First().ItemName, g.First().Brand, g.First().Division,
                    g.First().PoQty, g.Sum(x => x.AllocQty), g.Count()));
            if (_sortKey is null)
                return rows.OrderBy(r => r.OraPONo).ThenBy(r => r.ItemCode);
            Func<ItemSummaryRowVm, object?> k = _sortKey switch {
                "OraPONo" => r => r.OraPONo, "ItemCode" => r => r.ItemCode, "ItemName" => r => r.ItemName,
                "Brand" => r => r.Brand, "Division" => r => r.Division, "PoQty" => r => r.PoQty,
                "TotalAlloc" => r => r.TotalAlloc, "Stores" => r => r.Stores,
                _ => r => r.OraPONo,
            };
            return _sortAsc ? rows.OrderBy(k) : rows.OrderByDescending(k);
        }
    }

    private IEnumerable<StoreRowVm> StoreRows
    {
        get
        {
            var rows = FilteredAll
                .GroupBy(r => r.StoreID)
                .Select(g => new StoreRowVm(
                    g.Key, g.First().StoreName, g.First().Country, g.First().VolumeGroup,
                    g.First().MerchNeedMonth, g.First().Division,
                    string.Join(", ", g.Select(x => x.Brand).Where(b => b is not null).Distinct()),
                    g.Sum(x => x.PoQty), g.Sum(x => x.AllocQty)));
            if (_sortKey is null)
                return rows.OrderBy(r => r.StoreID);
            Func<StoreRowVm, object?> k = _sortKey switch {
                "StoreID" => r => r.StoreID, "StoreName" => r => r.StoreName, "Country" => r => r.Country,
                "VolumeGroup" => r => r.VolumeGroup, "MerchNeedMonth" => r => r.MerchNeedMonth,
                "Division" => r => r.Division, "Brand" => r => r.Brand,
                "PoQtySum" => r => r.PoQtySum, "AllocSum" => r => r.AllocSum,
                _ => r => r.StoreID,
            };
            return _sortAsc ? rows.OrderBy(k) : rows.OrderByDescending(k);
        }
    }

    private IEnumerable<CountrySummaryRowVm> CountrySummaryRows
    {
        get
        {
            // Stores Count = distinct StoreID per country (across the whole filtered set,
            // not just within the (Country, PO, Division) grouping)
            var all = FilteredAll.ToList();
            var storesPerCountry = all
                .GroupBy(r => r.Country)
                .ToDictionary(g => g.Key, g => g.Select(r => r.StoreID).Distinct().Count());

            var rows = all
                .GroupBy(r => new { r.Country, r.OraPONo, r.Division })
                .Select(g => new CountrySummaryRowVm(
                    g.Key.Country,
                    storesPerCountry.TryGetValue(g.Key.Country, out var n) ? n : 0,
                    g.Key.OraPONo, g.Key.Division,
                    // PO Qty per (Country, PO, Division) = sum of distinct PoQty per ItemCode
                    // (raw .Sum multi-counts because each item × store row repeats the same PoQty)
                    g.GroupBy(x => x.ItemCode).Sum(ig => ig.First().PoQty),
                    g.Sum(x => x.AllocQty)));
            if (_sortKey is null)
                return rows.OrderBy(r => r.Country).ThenBy(r => r.OraPONo).ThenBy(r => r.Division);
            Func<CountrySummaryRowVm, object?> k = _sortKey switch {
                "Country" => r => r.Country, "StoresCount" => r => r.StoresCount,
                "OraPONo" => r => r.OraPONo, "Division" => r => r.Division,
                "PoQty" => r => r.PoQty, "AllocQty" => r => r.AllocQty,
                _ => r => r.Country,
            };
            return _sortAsc ? rows.OrderBy(k) : rows.OrderByDescending(k);
        }
    }

    private void Sort(string key)
    {
        if (_sortKey == key) _sortAsc = !_sortAsc;
        else { _sortKey = key; _sortAsc = true; }
    }
    private string SortArrow(string key) => _sortKey == key ? (_sortAsc ? "▲" : "▼") : "";

    private void SetView(string v) { _view = v; _sortKey = null; _sortAsc = true; }
    private void ClearFilters()
    {
        _filterDivs.Clear(); _filterStores.Clear(); _filterPos.Clear(); _filterItemCode = "";
        _divSearch = ""; _storeSearch = ""; _poSearch = "";
    }
    private void ShowError(string msg) { _message = msg; _messageIsError = true; }
    private void ShowInfo(string msg)  { _message = msg; _messageIsError = false; }
}
