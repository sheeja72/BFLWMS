@page "/admin/audit"
@rendermode RenderMode.InteractiveServer
@attribute [Authorize(Roles = Wms.Core.Roles.Admin)]
@using Wms.Core.Entities
@using Wms.Data
@using Microsoft.EntityFrameworkCore
@inject IDbContextFactory<WmsDbContext> DbFactory

<PageTitle>WMS — Audit Log</PageTitle>

<div class="aiwms-page-header">
    <h2>Audit Log</h2>
    <p>All inserts, updates, deletes, and custom events captured for WMS-owned tables.</p>
</div>

<div class="aiwms-section">
    <div style="display:flex;gap:8px;margin-bottom:14px">
        <input @bind="_filterUser" placeholder="user contains..." style="padding:8px 12px;border:1px solid var(--border);border-radius:6px" />
        <input @bind="_filterEntity" placeholder="entity contains..." style="padding:8px 12px;border:1px solid var(--border);border-radius:6px" />
        <button class="aiwms-btn aiwms-btn-primary" @onclick="Reload">Filter</button>
    </div>

    <table class="aiwms-table">
        <thead><tr><th>TS</th><th>User</th><th>IP</th><th>Entity</th><th>Key</th><th>Action</th><th>Context</th><th>Changes</th></tr></thead>
        <tbody>
            @foreach (var r in _rows)
            {
                <tr>
                    <td>@r.ChangedTS.ToString("yyyy-MM-dd HH:mm:ss")</td>
                    <td>@r.ChangedBy</td>
                    <td>@r.ClientIp</td>
                    <td>@r.EntityName</td>
                    <td>@r.EntityKey</td>
                    <td>@r.Action</td>
                    <td>@r.Context</td>
                    <td style="font-family:Consolas,monospace;font-size:11px;max-width:400px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap">@r.ChangesJson</td>
                </tr>
            }
        </tbody>
    </table>
</div>

@code {
    private List<WmsAuditLog> _rows = new();
    private string _filterUser = "", _filterEntity = "";

    protected override async Task OnInitializedAsync() => await Reload();

    private async Task Reload()
    {
        await using var db = await DbFactory.CreateDbContextAsync();
        var q = db.AuditLogs.AsNoTracking();
        if (!string.IsNullOrWhiteSpace(_filterUser)) q = q.Where(r => r.ChangedBy.Contains(_filterUser));
        if (!string.IsNullOrWhiteSpace(_filterEntity)) q = q.Where(r => r.EntityName.Contains(_filterEntity));
        _rows = await q.OrderByDescending(r => r.ChangedTS).Take(500).ToListAsync();
    }
}
