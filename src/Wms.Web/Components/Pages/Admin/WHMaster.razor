@page "/admin/wh-master"
@rendermode RenderMode.InteractiveServer
@attribute [Authorize(Policy = Wms.Core.MenuKeys.ADMIN_WH_MASTER)]
@using Wms.Core.Entities
@using Wms.Data
@using Wms.Data.Lpm
@using Microsoft.EntityFrameworkCore
@inject IDbContextFactory<WmsDbContext> DbFactory
@inject BuildingService Build
@inject ICurrentUser Me
@inject ISnackbar Snack

<PageTitle>WMS — WH Master</PageTitle>

<div class="aiwms-page-header">
    <h2>Warehouse Master</h2>
    <p>Per-country warehouse list. Used to validate user profile and to populate <code>UPCBoxHeadLPM.WHouse</code> + <code>PhotocheckingLPM.Warehouse</code>.</p>
</div>

<div class="aiwms-section">
    <div class="aiwms-card-header">Add warehouse</div>
    <div class="aiwms-form-row">
        <label>Country</label>
        <select @bind="_country">
            <option value="">-- Select --</option>
            @foreach (var c in _countries) { <option value="@c">@c</option> }
        </select>
    </div>
    <div class="aiwms-form-row">
        <label>Warehouse</label>
        <input @bind="_warehouse" placeholder="e.g. DXBWH01" />
    </div>
    <div style="margin-top:8px">
        <button class="aiwms-btn aiwms-btn-primary" @onclick="Add" disabled="@(string.IsNullOrEmpty(_country) || string.IsNullOrEmpty(_warehouse))">Add</button>
    </div>
</div>

<div class="aiwms-section">
    <div class="aiwms-card-header">All warehouses</div>
    <table class="aiwms-table">
        <thead><tr><th>Country</th><th>Warehouse</th><th>Active</th><th>Created</th><th></th></tr></thead>
        <tbody>
            @foreach (var w in _whs)
            {
                <tr>
                    <td>@w.Country</td><td>@w.Warehouse</td><td>@(w.Active ? "Yes" : "No")</td>
                    <td>@w.CreateTS.ToString("yyyy-MM-dd")</td>
                    <td><button class="aiwms-btn aiwms-btn-secondary" @onclick="() => Toggle(w.Country, w.Warehouse)">@(w.Active ? "Disable" : "Enable")</button></td>
                </tr>
            }
        </tbody>
    </table>
</div>

@code {
    private List<WmsWHMaster> _whs = new();
    private List<string> _countries = new();
    private string _country = "", _warehouse = "";

    protected override async Task OnInitializedAsync()
    {
        await Me.EnsureLoadedAsync();
        try { _countries = await Build.GetAllSimCountriesAsync(); } catch { _countries = new(); }
        await Reload();
    }

    private async Task Reload()
    {
        await using var db = await DbFactory.CreateDbContextAsync();
        _whs = await db.WHMasters.AsNoTracking()
            .OrderBy(w => w.Country).ThenBy(w => w.Warehouse).ToListAsync();
    }

    private async Task Add()
    {
        await using var db = await DbFactory.CreateDbContextAsync();
        var exists = await db.WHMasters.FirstOrDefaultAsync(w => w.Country == _country && w.Warehouse == _warehouse);
        if (exists is null)
        {
            db.WHMasters.Add(new WmsWHMaster { Country = _country, Warehouse = _warehouse,
                Active = true, CreateTS = DateTime.Now, CreatedBy = Me.Name });
        }
        else { exists.Active = true; }
        await db.SaveChangesAsync();
        Snack.Add("Saved.", Severity.Success);
        _warehouse = "";
        await Reload();
    }

    private async Task Toggle(string country, string warehouse)
    {
        await using var db = await DbFactory.CreateDbContextAsync();
        var w = await db.WHMasters.FirstOrDefaultAsync(x => x.Country == country && x.Warehouse == warehouse);
        if (w is null) return;
        w.Active = !w.Active;
        await db.SaveChangesAsync();
        await Reload();
    }
}
