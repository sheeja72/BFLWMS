@page "/reports/missing-excess"
@rendermode RenderMode.InteractiveServer
@using System.Text
@using Wms.Core
@using Wms.Data.Lpm
@attribute [Authorize(Roles = "Admin,Reports")]
@inject ReportsService Svc
@inject Microsoft.JSInterop.IJSRuntime JS

<PageTitle>WMS — Missing / Excess Items from Production</PageTitle>

<div class="aiwms-page-header">
    <h2>Missing / Excess Items from Production</h2>
    <p>Box closure mismatches against AME checking, since the 21-Feb-2026 stocktake.</p>
</div>

<div class="aiwms-section">
    <div class="aiwms-card-header">Inputs</div>
    <div style="display:grid; grid-template-columns: 1fr 1fr 1fr auto; gap:12px; align-items:end;">
        <div>
            <label style="display:block; font-size:11px; font-weight:700; color:var(--text-secondary); margin-bottom:4px;">COUNTRY *</label>
            <select @bind="_country" style="width:100%; padding:8px 10px; border:1px solid var(--border-default); border-radius:var(--r-sm); font-family:var(--font-body); font-size:13px; background:white;">
                <option value="">-- Select --</option>
                @foreach (var c in _countries) { <option value="@c">@c</option> }
            </select>
        </div>
        <div>
            <label style="display:block; font-size:11px; font-weight:700; color:var(--text-secondary); margin-bottom:4px;">FROM</label>
            <input type="date" @bind="_fromDt" min="2026-02-21" max="@DateTime.Today.ToString("yyyy-MM-dd")" style="width:100%; padding:8px 10px; border:1px solid var(--border-default); border-radius:var(--r-sm); font-family:var(--font-body); font-size:13px; background:white;" />
        </div>
        <div>
            <label style="display:block; font-size:11px; font-weight:700; color:var(--text-secondary); margin-bottom:4px;">TO</label>
            <input type="date" @bind="_toDt" min="2026-02-21" max="@DateTime.Today.ToString("yyyy-MM-dd")" style="width:100%; padding:8px 10px; border:1px solid var(--border-default); border-radius:var(--r-sm); font-family:var(--font-body); font-size:13px; background:white;" />
        </div>
        <button class="aiwms-btn aiwms-btn-primary" @onclick="LoadAsync" disabled="@(_busy || !CanLoad)">Load</button>
    </div>

    <div style="display:flex; gap:14px; align-items:center; padding:12px 0 0 0; border-top:1px solid var(--border-default); margin-top:12px">
        <strong style="font-size:11px; text-transform:uppercase; letter-spacing:1px; color:var(--text-secondary)">Report:</strong>
        <label style="display:flex; align-items:center; gap:4px; cursor:pointer"><input type="radio" name="rv" value="BoxSummary"    checked="@(_view == "BoxSummary")"    @onchange="@(_ => SetView("BoxSummary"))"    /> Box Summary</label>
        <label style="display:flex; align-items:center; gap:4px; cursor:pointer"><input type="radio" name="rv" value="BoxMissing"    checked="@(_view == "BoxMissing")"    @onchange="@(_ => SetView("BoxMissing"))"    /> Box Detail — Missing</label>
        <label style="display:flex; align-items:center; gap:4px; cursor:pointer"><input type="radio" name="rv" value="BoxExcess"     checked="@(_view == "BoxExcess")"     @onchange="@(_ => SetView("BoxExcess"))"     /> Box Detail — Excess</label>
        <label style="display:flex; align-items:center; gap:4px; cursor:pointer"><input type="radio" name="rv" value="ItemSummary"   checked="@(_view == "ItemSummary")"   @onchange="@(_ => SetView("ItemSummary"))"   /> Item Summary</label>
    </div>

    @if (_busy)
    {
        <div style="margin-top:14px; padding:12px 14px; background:var(--bfl-yellow-lite); border:1px solid var(--bfl-yellow); border-radius:var(--r-sm); font-family:var(--font-display); font-size:13px; font-weight:800; color:var(--bfl-black)">Loading…</div>
    }
    @if (!string.IsNullOrEmpty(_message))
    {
        <div class="aiwms-alert @(_messageIsError ? "error" : "info")" style="margin-top:12px">@_message</div>
    }
</div>

@if (_loaded)
{
    <div class="aiwms-section">
        <div class="aiwms-card-header" style="display:flex; align-items:center; justify-content:space-between">
            <span>Result — @ResultCount rows</span>
            <button class="aiwms-btn aiwms-btn-secondary" @onclick="ExportCsvAsync">Export to Excel</button>
        </div>

        @if (_view == "BoxSummary")
        {
            <table class="aiwms-table aiwms-table-dense">
                <thead>
                    <tr>
                        <th style="cursor:pointer" @onclick='() => Sort("BoxNo")'>Box No @SortArrow("BoxNo")</th>
                        <th style="cursor:pointer" @onclick='() => Sort("ClosedDt")'>Closed Dt @SortArrow("ClosedDt")</th>
                        <th style="cursor:pointer" @onclick='() => Sort("ClosedBy")'>Closed By @SortArrow("ClosedBy")</th>
                        <th style="cursor:pointer; text-align:right" @onclick='() => Sort("MissQty")'>Missing Qty @SortArrow("MissQty")</th>
                        <th style="cursor:pointer; text-align:right" @onclick='() => Sort("ExcessQty")'>Excess Qty @SortArrow("ExcessQty")</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var r in SortedBoxSummary)
                    {
                        <tr>
                            <td>@r.BoxNo</td>
                            <td>@(r.ClosedDt?.ToString("yyyy-MM-dd"))</td>
                            <td>@r.ClosedBy</td>
                            <td style="text-align:right">@r.MissQty</td>
                            <td style="text-align:right">@r.ExcessQty</td>
                        </tr>
                    }
                </tbody>
            </table>
        }
        else if (_view == "BoxMissing" || _view == "BoxExcess")
        {
            var label = _view == "BoxMissing" ? "Missing" : "Excess";
            <table class="aiwms-table aiwms-table-dense">
                <thead>
                    <tr>
                        <th style="cursor:pointer" @onclick='() => Sort("BoxNo")'>Box No @SortArrow("BoxNo")</th>
                        <th style="cursor:pointer" @onclick='() => Sort("PreparedBy")'>Prepared By @SortArrow("PreparedBy")</th>
                        <th style="cursor:pointer" @onclick='() => Sort("ItemCode")'>Item Code @SortArrow("ItemCode")</th>
                        <th style="cursor:pointer; text-align:right" @onclick='() => Sort("Qty")'>Qty @SortArrow("Qty")</th>
                        <th style="cursor:pointer; text-align:right" @onclick='() => Sort("QtyIssued")'>Qty Issued @SortArrow("QtyIssued")</th>
                        <th style="cursor:pointer; text-align:right" @onclick='() => Sort("Diff")'>@label Qty @SortArrow("Diff")</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var r in SortedBoxDetail)
                    {
                        <tr>
                            <td>@r.BoxNo</td>
                            <td>@r.PreparedBy</td>
                            <td>@r.ItemCode</td>
                            <td style="text-align:right">@r.Qty</td>
                            <td style="text-align:right">@r.QtyIssued</td>
                            <td style="text-align:right">@r.Diff</td>
                        </tr>
                    }
                </tbody>
            </table>
        }
        else if (_view == "ItemSummary")
        {
            <table class="aiwms-table aiwms-table-dense">
                <thead>
                    <tr>
                        <th style="cursor:pointer" @onclick='() => Sort("ItemCode")'>Item Code @SortArrow("ItemCode")</th>
                        <th style="cursor:pointer" @onclick='() => Sort("ItemName")'>Item Name @SortArrow("ItemName")</th>
                        <th style="cursor:pointer" @onclick='() => Sort("Hierarchy")'>Hierarchy @SortArrow("Hierarchy")</th>
                        <th style="cursor:pointer" @onclick='() => Sort("Division")'>Division @SortArrow("Division")</th>
                        <th style="cursor:pointer" @onclick='() => Sort("Department")'>Department @SortArrow("Department")</th>
                        <th style="cursor:pointer; text-align:right" @onclick='() => Sort("MissingQty")'>Missing Qty @SortArrow("MissingQty")</th>
                        <th style="cursor:pointer; text-align:right" @onclick='() => Sort("ExcessQty")'>Excess Qty @SortArrow("ExcessQty")</th>
                        <th style="cursor:pointer; text-align:right" @onclick='() => Sort("HOStock")'>HO Stock @SortArrow("HOStock")</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var r in SortedItemSummary)
                    {
                        <tr>
                            <td>@r.ItemCode</td>
                            <td>@r.ItemName</td>
                            <td>@r.Hierarchy</td>
                            <td>@r.Division</td>
                            <td>@r.Department</td>
                            <td style="text-align:right">@r.MissingQty</td>
                            <td style="text-align:right">@r.ExcessQty</td>
                            <td style="text-align:right">@r.HOStock</td>
                        </tr>
                    }
                </tbody>
            </table>
        }
    </div>
}

@code {
    private List<string> _countries = new();
    private List<BoxSummaryRow>          _boxSummary = new();
    private List<BoxDetailRow>           _boxDetail  = new();
    private List<ItemSummaryReportRow>   _itemSummary = new();

    private string   _country = "";
    private DateTime _fromDt  = new DateTime(2026, 2, 21);
    private DateTime _toDt    = DateTime.Today;
    private string   _view    = "BoxSummary";
    private bool     _busy;
    private bool     _loaded;
    private string   _message = "";
    private bool     _messageIsError;
    private string?  _sortKey;
    private bool     _sortAsc = true;

    private bool CanLoad => !string.IsNullOrWhiteSpace(_country)
                         && _fromDt >= new DateTime(2026, 2, 21)
                         && _toDt   >= _fromDt;

    private int ResultCount => _view switch
    {
        "BoxSummary"  => _boxSummary.Count,
        "BoxMissing"  => _boxDetail.Count,
        "BoxExcess"   => _boxDetail.Count,
        "ItemSummary" => _itemSummary.Count,
        _ => 0,
    };

    protected override async Task OnInitializedAsync()
    {
        try { _countries = await Svc.GetCountriesAsync(); }
        catch (Exception ex) { ShowError($"Failed to load countries: {ex.Message}"); }
    }

    private async Task LoadAsync()
    {
        if (!CanLoad) return;
        _busy = true; _message = ""; _loaded = false; _sortKey = null;
        try
        {
            switch (_view)
            {
                case "BoxSummary":  _boxSummary  = await Svc.BoxSummaryAsync(_country, _fromDt, _toDt); break;
                case "BoxMissing":  _boxDetail   = await Svc.BoxDetailMissingAsync(_country, _fromDt, _toDt); break;
                case "BoxExcess":   _boxDetail   = await Svc.BoxDetailExcessAsync(_country, _fromDt, _toDt); break;
                case "ItemSummary": _itemSummary = await Svc.ItemSummaryAsync(_country, _fromDt, _toDt); break;
            }
            _loaded = true;
            ShowInfo($"Loaded {ResultCount} rows.");
        }
        catch (Exception ex) { ShowError($"Load failed: {ex.Message}"); }
        finally { _busy = false; }
    }

    private void SetView(string v)
    {
        _view = v; _sortKey = null; _loaded = false;
    }
    private void Sort(string key)
    {
        if (_sortKey == key) _sortAsc = !_sortAsc;
        else { _sortKey = key; _sortAsc = true; }
    }
    private string SortArrow(string key) => _sortKey == key ? (_sortAsc ? "▲" : "▼") : "";

    private IEnumerable<BoxSummaryRow> SortedBoxSummary
    {
        get
        {
            if (_sortKey is null) return _boxSummary.OrderByDescending(r => r.ClosedDt);
            Func<BoxSummaryRow, object?> k = _sortKey switch {
                "BoxNo" => r => r.BoxNo, "ClosedDt" => r => r.ClosedDt, "ClosedBy" => r => r.ClosedBy,
                "MissQty" => r => r.MissQty, "ExcessQty" => r => r.ExcessQty,
                _ => r => r.BoxNo,
            };
            return _sortAsc ? _boxSummary.OrderBy(k) : _boxSummary.OrderByDescending(k);
        }
    }
    private IEnumerable<BoxDetailRow> SortedBoxDetail
    {
        get
        {
            if (_sortKey is null) return _boxDetail.OrderBy(r => r.BoxNo).ThenBy(r => r.ItemCode);
            Func<BoxDetailRow, object?> k = _sortKey switch {
                "BoxNo" => r => r.BoxNo, "PreparedBy" => r => r.PreparedBy, "ItemCode" => r => r.ItemCode,
                "Qty" => r => r.Qty, "QtyIssued" => r => r.QtyIssued, "Diff" => r => r.Diff,
                _ => r => r.BoxNo,
            };
            return _sortAsc ? _boxDetail.OrderBy(k) : _boxDetail.OrderByDescending(k);
        }
    }
    private IEnumerable<ItemSummaryReportRow> SortedItemSummary
    {
        get
        {
            if (_sortKey is null) return _itemSummary.OrderBy(r => r.ItemCode);
            Func<ItemSummaryReportRow, object?> k = _sortKey switch {
                "ItemCode" => r => r.ItemCode, "ItemName" => r => r.ItemName, "Hierarchy" => r => r.Hierarchy,
                "Division" => r => r.Division, "Department" => r => r.Department,
                "MissingQty" => r => r.MissingQty, "ExcessQty" => r => r.ExcessQty, "HOStock" => r => r.HOStock,
                _ => r => r.ItemCode,
            };
            return _sortAsc ? _itemSummary.OrderBy(k) : _itemSummary.OrderByDescending(k);
        }
    }

    private async Task ExportCsvAsync()
    {
        var sb = new StringBuilder();
        switch (_view)
        {
            case "BoxSummary":
                sb.AppendLine("BoxNo,ClosedDt,ClosedBy,MissingQty,ExcessQty");
                foreach (var r in SortedBoxSummary)
                    sb.AppendLine($"{Csv(r.BoxNo)},{r.ClosedDt:yyyy-MM-dd},{Csv(r.ClosedBy)},{r.MissQty},{r.ExcessQty}");
                break;
            case "BoxMissing":
            case "BoxExcess":
                var label = _view == "BoxMissing" ? "MissingQty" : "ExcessQty";
                sb.AppendLine($"BoxNo,PreparedBy,ItemCode,Qty,QtyIssued,{label}");
                foreach (var r in SortedBoxDetail)
                    sb.AppendLine($"{Csv(r.BoxNo)},{Csv(r.PreparedBy)},{Csv(r.ItemCode)},{r.Qty},{r.QtyIssued},{r.Diff}");
                break;
            case "ItemSummary":
                sb.AppendLine("ItemCode,ItemName,Hierarchy,Division,Department,MissingQty,ExcessQty,HOStock");
                foreach (var r in SortedItemSummary)
                    sb.AppendLine($"{Csv(r.ItemCode)},{Csv(r.ItemName)},{Csv(r.Hierarchy)},{Csv(r.Division)},{Csv(r.Department)},{r.MissingQty},{r.ExcessQty},{r.HOStock}");
                break;
        }
        var b64 = Convert.ToBase64String(Encoding.UTF8.GetBytes(sb.ToString()));
        var filename = $"missing_excess_{_country}_{_view}_{_fromDt:yyyyMMdd}_{_toDt:yyyyMMdd}.csv";
        await JS.InvokeVoidAsync("eval", $"(function(){{var a=document.createElement('a');a.href='data:text/csv;base64,{b64}';a.download='{filename}';document.body.appendChild(a);a.click();document.body.removeChild(a);}})();");
    }

    private static string Csv(string? s) => s is null ? ""
        : (s.Contains(',') || s.Contains('"') || s.Contains('\n')) ? "\"" + s.Replace("\"", "\"\"") + "\"" : s;

    private void ShowError(string msg) { _message = msg; _messageIsError = true; }
    private void ShowInfo(string msg)  { _message = msg; _messageIsError = false; }
}
