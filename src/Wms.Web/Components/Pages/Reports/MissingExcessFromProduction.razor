@page "/reports/missing-excess"
@rendermode RenderMode.InteractiveServer
@using System.Text
@using Wms.Core
@using Wms.Data.Lpm
@attribute [Authorize(Policy = MenuKeys.RPT_MISSING_EXCESS)]
@inject ReportsService Svc
@inject Microsoft.JSInterop.IJSRuntime JS

<PageTitle>WMS — Missing / Excess Items from Production</PageTitle>

<div class="aiwms-page-header">
    <h2>Missing / Excess Items from Production</h2>
    <p>Box closure mismatches against AME checking, since the 21-Feb-2026 stocktake.</p>
</div>

<div class="aiwms-section">
    <div class="aiwms-card-header">Inputs</div>
    <div style="display:grid; grid-template-columns: 1fr 1fr 1fr auto; gap:12px; align-items:end;">
        <div>
            <label style="display:block; font-size:11px; font-weight:700; color:var(--text-secondary); margin-bottom:4px;">COUNTRY *</label>
            <select @bind="_country" style="width:100%; padding:8px 10px; border:1px solid var(--border-default); border-radius:var(--r-sm); font-family:var(--font-body); font-size:13px; background:white;">
                <option value="">-- Select --</option>
                @foreach (var c in _countries) { <option value="@c">@c</option> }
            </select>
        </div>
        <div>
            <label style="display:block; font-size:11px; font-weight:700; color:var(--text-secondary); margin-bottom:4px;">FROM</label>
            <input type="date" @bind="_fromDt" min="2026-02-21" max="@DateTime.Today.ToString("yyyy-MM-dd")" style="width:100%; padding:8px 10px; border:1px solid var(--border-default); border-radius:var(--r-sm); font-family:var(--font-body); font-size:13px; background:white;" />
        </div>
        <div>
            <label style="display:block; font-size:11px; font-weight:700; color:var(--text-secondary); margin-bottom:4px;">TO</label>
            <input type="date" @bind="_toDt" min="2026-02-21" max="@DateTime.Today.ToString("yyyy-MM-dd")" style="width:100%; padding:8px 10px; border:1px solid var(--border-default); border-radius:var(--r-sm); font-family:var(--font-body); font-size:13px; background:white;" />
        </div>
        <button class="aiwms-btn aiwms-btn-primary" @onclick="LoadAsync" disabled="@(_busy || !CanLoad)">Load</button>
    </div>

    <div style="display:flex; gap:14px; align-items:center; padding:12px 0 0 0; border-top:1px solid var(--border-default); margin-top:12px">
        <strong style="font-size:11px; text-transform:uppercase; letter-spacing:1px; color:var(--text-secondary)">Report:</strong>
        <label style="display:flex; align-items:center; gap:4px; cursor:pointer"><input type="radio" name="rv" value="BoxSummary"  checked="@(_view == "BoxSummary")"  @onchange="@(_ => SetView("BoxSummary"))"  /> Box Summary</label>
        <label style="display:flex; align-items:center; gap:4px; cursor:pointer"><input type="radio" name="rv" value="BoxDetail"   checked="@(_view == "BoxDetail")"   @onchange="@(_ => SetView("BoxDetail"))"   /> Box Detail (Excel only)</label>
        <label style="display:flex; align-items:center; gap:4px; cursor:pointer"><input type="radio" name="rv" value="ItemSummary" checked="@(_view == "ItemSummary")" @onchange="@(_ => SetView("ItemSummary"))" /> Item Summary</label>
    </div>

    @if (_busy)
    {
        <div style="margin-top:14px; padding:12px 14px; background:var(--bfl-yellow-lite); border:1px solid var(--bfl-yellow); border-radius:var(--r-sm); font-family:var(--font-display); font-size:13px; font-weight:800; color:var(--bfl-black)">@(_busyMsg ?? "Loading…")</div>
    }
    @if (!string.IsNullOrEmpty(_message))
    {
        <div class="aiwms-alert @(_messageIsError ? "error" : "info")" style="margin-top:12px">@_message</div>
    }
</div>

@if (_view == "BoxDetail")
{
    <div class="aiwms-section">
        <div class="aiwms-card-header" style="display:flex; align-items:center; justify-content:space-between">
            <span>Box Detail — Excel only (Missing + Excess combined)</span>
            <button class="aiwms-btn aiwms-btn-secondary" @onclick="ExportBoxDetailAsync" disabled="@(_busy || !CanLoad)">Export to Excel</button>
        </div>
        <div style="padding:12px 14px; font-size:13px; color:var(--text-secondary)">
            UI table skipped for this view because the row count is large.
            Click Export to Excel to download Missing + Excess rows as CSV (with a Type column).
        </div>
    </div>
}
else if (_loaded && _view == "BoxSummary")
{
    <div class="aiwms-section">
        <div style="display:grid; grid-template-columns: 1fr 1fr 1fr; gap:12px; padding:0 0 14px 0">
            <div style="background:#dcfce7; color:#166534; padding:12px 16px; border-radius:var(--r-sm); border:1px solid #00000010">
                <div style="font-size:11px; font-weight:700; text-transform:uppercase; letter-spacing:1px">Total Boxes</div>
                <div style="font-size:1.6rem; font-weight:900">@_boxMonths.Sum(r => r.BoxCount).ToString("N0")</div>
            </div>
            <div style="background:#fee2e2; color:#991b1b; padding:12px 16px; border-radius:var(--r-sm); border:1px solid #00000010">
                <div style="font-size:11px; font-weight:700; text-transform:uppercase; letter-spacing:1px">Total Missing Qty</div>
                <div style="font-size:1.6rem; font-weight:900">@_boxMonths.Sum(r => r.MissQty).ToString("N0")</div>
            </div>
            <div style="background:#fef3c7; color:#92400e; padding:12px 16px; border-radius:var(--r-sm); border:1px solid #00000010">
                <div style="font-size:11px; font-weight:700; text-transform:uppercase; letter-spacing:1px">Total Excess Qty</div>
                <div style="font-size:1.6rem; font-weight:900">@_boxMonths.Sum(r => r.ExcessQty).ToString("N0")</div>
            </div>
        </div>
        <div class="aiwms-card-header" style="display:flex; align-items:center; justify-content:space-between">
            <span>Box Summary by Month — @_boxMonths.Count rows</span>
            <button class="aiwms-btn aiwms-btn-secondary" @onclick="ExportBoxSummaryAsync" disabled="@_busy">Export to Excel</button>
        </div>
        <table class="aiwms-table aiwms-table-dense">
            <thead>
                <tr>
                    <th style="cursor:pointer" @onclick='() => Sort("Month")'>Month @SortArrow("Month")</th>
                    <th style="cursor:pointer; text-align:right" @onclick='() => Sort("BoxCount")'>Box Count @SortArrow("BoxCount")</th>
                    <th style="cursor:pointer; text-align:right" @onclick='() => Sort("MissQty")'>Missing Qty @SortArrow("MissQty")</th>
                    <th style="cursor:pointer; text-align:right" @onclick='() => Sort("ExcessQty")'>Excess Qty @SortArrow("ExcessQty")</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var r in SortedBoxMonths)
                {
                    <tr>
                        <td>@r.Month</td>
                        <td style="text-align:right">@r.BoxCount</td>
                        <td style="text-align:right">@r.MissQty</td>
                        <td style="text-align:right">@r.ExcessQty</td>
                    </tr>
                }
                <tr style="font-weight:700; background:#fff7e0;">
                    <td>TOTAL</td>
                    <td style="text-align:right">@_boxMonths.Sum(r => r.BoxCount)</td>
                    <td style="text-align:right">@_boxMonths.Sum(r => r.MissQty)</td>
                    <td style="text-align:right">@_boxMonths.Sum(r => r.ExcessQty)</td>
                </tr>
            </tbody>
        </table>
    </div>
}
else if (_loaded && _view == "ItemSummary")
{
    <div class="aiwms-section">
        <div style="display:grid; grid-template-columns: 1fr 1fr 1fr; gap:12px; padding:0 0 14px 0">
            <div style="background:#fee2e2; color:#991b1b; padding:12px 16px; border-radius:var(--r-sm); border:1px solid #00000010">
                <div style="font-size:11px; font-weight:700; text-transform:uppercase; letter-spacing:1px">Total Missing Qty</div>
                <div style="font-size:1.6rem; font-weight:900">@_itemDivDept.Sum(r => r.MissingQty).ToString("N0")</div>
            </div>
            <div style="background:#fef3c7; color:#92400e; padding:12px 16px; border-radius:var(--r-sm); border:1px solid #00000010">
                <div style="font-size:11px; font-weight:700; text-transform:uppercase; letter-spacing:1px">Total Excess Qty</div>
                <div style="font-size:1.6rem; font-weight:900">@_itemDivDept.Sum(r => r.ExcessQty).ToString("N0")</div>
            </div>
            <div style="background:#dbeafe; color:#1e40af; padding:12px 16px; border-radius:var(--r-sm); border:1px solid #00000010">
                <div style="font-size:11px; font-weight:700; text-transform:uppercase; letter-spacing:1px">Total HO Stock</div>
                <div style="font-size:1.6rem; font-weight:900">@_itemDivDept.Sum(r => r.HOStock).ToString("N0")</div>
            </div>
        </div>
        <div class="aiwms-card-header" style="display:flex; align-items:center; justify-content:space-between">
            <span>Item Summary by Division × Department — @_itemDivDept.Count rows</span>
            <button class="aiwms-btn aiwms-btn-secondary" @onclick="ExportItemDetailsAsync" disabled="@_busy">Item Details Export</button>
        </div>
        <table class="aiwms-table aiwms-table-dense">
            <thead>
                <tr>
                    <th style="cursor:pointer" @onclick='() => Sort("Division")'>Division @SortArrow("Division")</th>
                    <th style="cursor:pointer" @onclick='() => Sort("Department")'>Department @SortArrow("Department")</th>
                    <th style="cursor:pointer; text-align:right" @onclick='() => Sort("MissingQty")'>Missing Qty @SortArrow("MissingQty")</th>
                    <th style="cursor:pointer; text-align:right" @onclick='() => Sort("ExcessQty")'>Excess Qty @SortArrow("ExcessQty")</th>
                    <th style="cursor:pointer; text-align:right" @onclick='() => Sort("HOStock")'>HO Stock @SortArrow("HOStock")</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var r in SortedItemDivDept)
                {
                    <tr>
                        <td>@r.Division</td>
                        <td>@r.Department</td>
                        <td style="text-align:right">@r.MissingQty</td>
                        <td style="text-align:right">@r.ExcessQty</td>
                        <td style="text-align:right">@r.HOStock</td>
                    </tr>
                }
                <tr style="font-weight:700; background:#fff7e0;">
                    <td colspan="2">TOTAL</td>
                    <td style="text-align:right">@_itemDivDept.Sum(r => r.MissingQty)</td>
                    <td style="text-align:right">@_itemDivDept.Sum(r => r.ExcessQty)</td>
                    <td style="text-align:right">@_itemDivDept.Sum(r => r.HOStock)</td>
                </tr>
            </tbody>
        </table>
    </div>
}

@code {
    private List<string> _countries = new();
    private List<BoxSummaryMonthRow>     _boxMonths   = new();
    private List<ItemSummaryByDivDeptRow> _itemDivDept = new();

    private string   _country = "";
    private DateTime _fromDt  = new DateTime(2026, 2, 21);
    private DateTime _toDt    = DateTime.Today;
    private string   _view    = "BoxSummary";
    private bool     _busy;
    private string?  _busyMsg;
    private bool     _loaded;
    private string   _message = "";
    private bool     _messageIsError;
    private string?  _sortKey;
    private bool     _sortAsc = true;

    private bool CanLoad => !string.IsNullOrWhiteSpace(_country)
                         && _fromDt >= new DateTime(2026, 2, 21)
                         && _toDt   >= _fromDt;

    protected override async Task OnInitializedAsync()
    {
        try { _countries = await Svc.GetCountriesAsync(); }
        catch (Exception ex) { ShowError($"Failed to load countries: {ex.Message}"); }
    }

    private async Task LoadAsync()
    {
        if (!CanLoad) return;
        _busy = true; _busyMsg = "Loading…"; _message = ""; _loaded = false; _sortKey = null;
        try
        {
            switch (_view)
            {
                case "BoxSummary":  _boxMonths   = await Svc.BoxSummaryByMonthFromSnapshotAsync(_country, _fromDt, _toDt); break;
                case "ItemSummary": _itemDivDept = await Svc.ItemSummaryByDivDeptFromSnapshotAsync(_country, _fromDt, _toDt); break;
                case "BoxDetail":   /* no UI — Export does the work */ break;
            }
            _loaded = true;
            var count = _view == "BoxSummary" ? _boxMonths.Count
                      : _view == "ItemSummary" ? _itemDivDept.Count
                      : 0;
            ShowInfo(_view == "BoxDetail" ? "Ready — click Export to Excel." : $"Loaded {count} rows.");
        }
        catch (Exception ex) { ShowError($"Load failed: {ex.Message}"); }
        finally { _busy = false; _busyMsg = null; }
    }

    private void SetView(string v) { _view = v; _sortKey = null; _loaded = false; _message = ""; }
    private void Sort(string key)
    {
        if (_sortKey == key) _sortAsc = !_sortAsc;
        else { _sortKey = key; _sortAsc = true; }
    }
    private string SortArrow(string key) => _sortKey == key ? (_sortAsc ? "▲" : "▼") : "";

    private IEnumerable<BoxSummaryMonthRow> SortedBoxMonths
    {
        get
        {
            if (_sortKey is null) return _boxMonths.OrderBy(r => r.Month);
            Func<BoxSummaryMonthRow, object?> k = _sortKey switch {
                "Month" => r => r.Month, "BoxCount" => r => r.BoxCount,
                "MissQty" => r => r.MissQty, "ExcessQty" => r => r.ExcessQty,
                _ => r => r.Month,
            };
            return _sortAsc ? _boxMonths.OrderBy(k) : _boxMonths.OrderByDescending(k);
        }
    }

    private IEnumerable<ItemSummaryByDivDeptRow> SortedItemDivDept
    {
        get
        {
            if (_sortKey is null) return _itemDivDept.OrderBy(r => r.Division).ThenBy(r => r.Department);
            Func<ItemSummaryByDivDeptRow, object?> k = _sortKey switch {
                "Division" => r => r.Division, "Department" => r => r.Department,
                "MissingQty" => r => r.MissingQty, "ExcessQty" => r => r.ExcessQty, "HOStock" => r => r.HOStock,
                _ => r => r.Division,
            };
            return _sortAsc ? _itemDivDept.OrderBy(k) : _itemDivDept.OrderByDescending(k);
        }
    }

    private async Task ExportBoxSummaryAsync()
    {
        _busy = true; _busyMsg = "Building Box Summary export…"; await InvokeAsync(StateHasChanged);
        try
        {
            var rows = await Svc.BoxSummaryFromSnapshotAsync(_country, _fromDt, _toDt);
            var sb = new StringBuilder();
            sb.AppendLine("BoxNo,ClosedDt,ClosedBy,MissingQty,ExcessQty");
            foreach (var r in rows)
                sb.AppendLine($"{Csv(r.BoxNo)},{r.ClosedDt:yyyy-MM-dd},{Csv(r.ClosedBy)},{r.MissQty},{r.ExcessQty}");
            await DownloadCsv(sb.ToString(), "BoxSummary");
            ShowInfo($"Exported {rows.Count} rows.");
        }
        catch (Exception ex) { ShowError($"Export failed: {ex.Message}"); }
        finally { _busy = false; _busyMsg = null; }
    }

    private async Task ExportBoxDetailAsync()
    {
        if (!CanLoad) return;
        _busy = true; _busyMsg = "Building Box Detail export…"; await InvokeAsync(StateHasChanged);
        try
        {
            var rows = await Svc.BoxDetailCombinedFromSnapshotAsync(_country, _fromDt, _toDt);
            var sb = new StringBuilder();
            sb.AppendLine("BoxNo,PreparedBy,ItemCode,Qty,QtyIssued,Missing,Excess");
            foreach (var r in rows)
                sb.AppendLine($"{Csv(r.BoxNo)},{Csv(r.PreparedBy)},{Csv(r.ItemCode)},{r.Qty},{r.QtyIssued},{r.MissingQty},{r.ExcessQty}");
            await DownloadCsv(sb.ToString(), "BoxDetail");
            ShowInfo($"Exported {rows.Count} rows.");
        }
        catch (Exception ex) { ShowError($"Export failed: {ex.Message}"); }
        finally { _busy = false; _busyMsg = null; }
    }

    private async Task ExportItemDetailsAsync()
    {
        _busy = true; _busyMsg = "Building Item Details export…"; await InvokeAsync(StateHasChanged);
        try
        {
            var rows = await Svc.ItemSummaryFromSnapshotAsync(_country, _fromDt, _toDt);
            var sb = new StringBuilder();
            sb.AppendLine("ItemCode,ItemName,Division,Department,MissingQty,ExcessQty,HOStock");
            foreach (var r in rows)
                sb.AppendLine($"{Csv(r.ItemCode)},{Csv(r.ItemName)},{Csv(r.Division)},{Csv(r.Department)},{r.MissingQty},{r.ExcessQty},{r.HOStock}");
            await DownloadCsv(sb.ToString(), "ItemDetails");
            ShowInfo($"Exported {rows.Count} rows.");
        }
        catch (Exception ex) { ShowError($"Export failed: {ex.Message}"); }
        finally { _busy = false; _busyMsg = null; }
    }

    private async Task DownloadCsv(string csv, string viewName)
    {
        var b64 = Convert.ToBase64String(Encoding.UTF8.GetBytes(csv));
        var filename = $"missing_excess_{_country}_{viewName}_{_fromDt:yyyyMMdd}_{_toDt:yyyyMMdd}.csv";
        await JS.InvokeVoidAsync("eval", $"(function(){{var a=document.createElement('a');a.href='data:text/csv;base64,{b64}';a.download='{filename}';document.body.appendChild(a);a.click();document.body.removeChild(a);}})();");
    }

    private static string Csv(string? s) => s is null ? ""
        : (s.Contains(',') || s.Contains('"') || s.Contains('\n')) ? "\"" + s.Replace("\"", "\"\"") + "\"" : s;

    private void ShowError(string msg) { _message = msg; _messageIsError = true; }
    private void ShowInfo(string msg)  { _message = msg; _messageIsError = false; }
}
