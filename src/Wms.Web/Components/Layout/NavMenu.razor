@using Wms.Core
@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Components.Authorization
@inject AuthenticationStateProvider AuthProvider
@inject IAuthorizationService AuthService

<nav class="aiwms-nav">
    <NavLink class="aiwms-nav-link" ActiveClass="active" href="" Match="NavLinkMatch.All">
        <span class="aiwms-nav-icon">home</span>
        <span>Home</span>
    </NavLink>

    @{
        // Section header only renders if at least one menu inside is visible.
        var grouped = MenuKeys.All
            .Where(m => _visible.Contains(m.Key))
            .GroupBy(m => m.Group)
            .ToList();
    }
    @foreach (var grp in grouped)
    {
        <div class="aiwms-nav-section">@grp.Key</div>
        @foreach (var menu in grp)
        {
            <NavLink class="aiwms-nav-link" ActiveClass="active" href="@menu.Url">
                <span class="aiwms-nav-icon">@IconFor(menu.Key)</span>
                <span>@menu.Label</span>
            </NavLink>
        }
    }
</nav>

@code {
    private HashSet<string> _visible = new();

    protected override async Task OnInitializedAsync()
    {
        var auth = await AuthProvider.GetAuthenticationStateAsync();
        var user = auth.User;
        foreach (var menu in MenuKeys.All)
        {
            var result = await AuthService.AuthorizeAsync(user, null, menu.Key);
            if (result.Succeeded) _visible.Add(menu.Key);
        }
    }

    private static string IconFor(string key) => key switch
    {
        MenuKeys.LPM_MANUAL_BUILDING       => "inventory_2",
        MenuKeys.CONTAINER_ALLOCATION      => "assignment_turned_in",
        MenuKeys.OPEN_CONTAINER            => "lock_open",
        MenuKeys.DATASYNC_CONTAINER_ALLOCATION => "sync_alt",
        MenuKeys.ITEM_ENCODING             => "sell",
        MenuKeys.LPM_PRODUCTION            => "local_shipping",
        MenuKeys.RPT_MISSING_EXCESS        => "assessment",
        MenuKeys.RPT_NON_LPM_WH_STOCK      => "inventory_2",
        MenuKeys.RPT_LPM_WH_STOCK          => "inventory",
        MenuKeys.RPT_PRODUCTION_SUMMARY    => "qr_code_scanner",
        MenuKeys.RPT_WAREHOUSE_BOXES       => "warehouse",
        MenuKeys.RPT_RACKS                 => "shelves",
        MenuKeys.ADMIN_USERS               => "group",
        MenuKeys.ADMIN_WH_MASTER           => "apartment",
        MenuKeys.ADMIN_AUDIT_LOG           => "history",
        MenuKeys.ADMIN_NIGHTLY_BATCHES     => "schedule",
        _ => "circle",
    };
}
